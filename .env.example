# Google Cloud Natural Language API Key
# Get from: https://console.cloud.google.com/apis/credentials
# Look for "API key for python" in the credentials page
GCNL_API_KEY=KEY_EXAMPLE

# Firebase Project ID (required for local development)
FIREBASE_PROJECT_ID=final-project-494621

# Path to Firebase service account JSON file (required for local development)
# Download from: https://console.cloud.google.com/project/final-project-494621/settings/serviceaccounts/adminsdk
# Click "Generate new private key" and save the JSON file to your local machine
# Example: ~/.config/gcp/final-project-494621-firebase-adminsdk.json
# copy it as a one line json file, can find online helpers to do so
FIREBASE_SERVICE_ACCOUNT_JSON=onelinejsonfile